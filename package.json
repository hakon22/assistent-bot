{
  "name": "assistent-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx tsc && npx tsc-alias --resolve-full-paths",
    "start:bot:dev": "cross-env DB='LOCAL' NODE_ENV=development tsx src/bot.ts",
    "start:bot:prod": "cross-env DB='HOST' NODE_ENV=production node src/bot.js",
    "start:bot:docker:dev": "cross-env DB='LOCAL' IS_DOCKER='TRUE' NODE_ENV=development node src/bot.js",
    "lint": "eslint ./src",
    "migration:create": "typeorm migration:create",
    "migration:create:name": "tsx ./src/db/migrations/helpers/create.migration.helper.ts",
    "migration:run": "cross-env DB='LOCAL' CRON='TRUE' tsx ./node_modules/typeorm/cli.js migration:run --dataSource ./src/db/database.service.ts",
    "migration:run:prod": "cross-env DB='HOST' CRON='TRUE' NODE_ENV=production node ./node_modules/typeorm/cli.js migration:run --dataSource ./src/db/database.service.js",
    "migration:revert": "cross-env CRON='TRUE' tsx ./node_modules/typeorm/cli.js migration:revert --dataSource ./src/db/database.service.ts"
  },
  "dependencies": {
    "@langchain/langgraph": "1.2.2",
    "@langchain/openai": "1.2.13",
    "axios": "1.13.6",
    "dotenv": "17.2.3",
    "langchain": "1.2.32",
    "lodash": "4.17.21",
    "moment": "2.30.1",
    "moment-timezone": "0.6.0",
    "pdf2json": "4.0.2",
    "pg": "8.13.1",
    "playwright": "1.44.0",
    "reflect-metadata": "0.2.2",
    "socks-proxy-agent": "8.0.5",
    "telegraf": "4.16.3",
    "typeorm": "0.3.20",
    "typescript-ioc": "3.2.2",
    "winston": "3.18.3",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@types/express": "5.0.6",
    "@types/lodash": "4.17.21",
    "@types/node": "24.10.1",
    "@typescript-eslint/eslint-plugin": "8.48.1",
    "@typescript-eslint/parser": "8.48.1",
    "cross-env": "10.1.0",
    "eslint": "9.39.1",
    "express": "4.22.1",
    "globals": "16.5.0",
    "tsc-alias": "1.8.10",
    "tsx": "4.19.2",
    "typescript": "5.9.3"
  }
}
